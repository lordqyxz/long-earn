# Long Earn 环境变量配置
# 复制此文件为 .env 并根据需要修改

# ── LLM 配置 ────────────────────────────────────────────────────
# 支持三种 LLM 类型：ollama / dashscope / openai
# 切换方式：修改 LLM_TYPE 和对应的配置即可

# 方式一：本地 Ollama（默认）
LLM_TYPE=ollama
LLM_MODEL=deepseek-v4-flash:cloud
LLM_BASE_URL=http://localhost:11434

# 方式二：阿里百炼 DashScope
# LLM_TYPE=dashscope
# LLM_MODEL=qwen-plus
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# 方式三：OpenAI 兼容 API
# LLM_TYPE=openai
# LLM_MODEL=gpt-4
# LLM_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# ── 记忆系统（物质-运动架构，JSONL）──────────────────────────────
MEMORY_PATH=~/.long_earn/substances.jsonl

# ── 知识库初始化目录 ────────────────────────────────────────────
INIT_DIR=./init

# ── 策略研发 ────────────────────────────────────────────────────
MAX_ITERATIONS=3

# ── 回测引擎 ────────────────────────────────────────────────────
BACKTEST_START_DATE=2020-01-01
BACKTEST_END_DATE=2023-12-31

# ── 意图路由关键词（逗号分隔）────────────────────────────────────
STRATEGY_KEYWORDS=策略,思路,投资策略
STOCK_ANALYSIS_KEYWORDS=股票,分析,公司
# ── xtquant 数据源开关 ─────────────────────────────────────────
# 当本机无 miniQMT 客户端连接时（CI / 纯开发机），设为 1 强制走 DuckDB 缓存路径，
# 避免 xtquant C++ 端在查询时触发 SIGABRT 让 Python 进程整体崩溃。
# LONG_EARN_DISABLE_XTQUANT=1
